+def run_single_query(sample: dict, agent_kwargs: dict) -> dict:
+    """Run Reflexion on one HotpotQA sample.
+
+    Args:
+        sample: HotpotQA dataset entry with 'question' and 'answer'.
+        agent_kwargs:
+            fewshot (int): number of in-context examples.
+            iteration_limit (int): per-trial max steps.
+            reflection_limit (int): max number of trials (outer loop).
+            context_limit (int): scratchpad token cap.
+            callbacks (list[BaseCallbackHandler] | None).
+            model (str), base_url (str | None), temperature (float),
+            print_log (bool).
+
+    Returns:
+        dict with keys: answer, raw_messages, iterations.
+    """
+    from src.tools.hotpotqa_tools.wikipedia import LookupTool, WikipediaTool, FinishTool
+    from src.utils import get_evaluation_function
+
+    callbacks = agent_kwargs.get("callbacks") or []
+    fewshot = int(agent_kwargs.get("fewshot", 0))
+    iteration_limit = int(agent_kwargs.get("iteration_limit", 7))
+    reflection_limit = int(agent_kwargs.get("reflection_limit", 3))
+    context_limit = int(agent_kwargs.get("context_limit", 4096))
+    model_name = agent_kwargs.get("model", "Meta-Llama-3.1-8B-Instruct-Q4_K_M")
+    base_url = agent_kwargs.get("base_url")
+    temperature = float(agent_kwargs.get("temperature", 0.0))
+    print_log = bool(agent_kwargs.get("print_log", False))
+
+    llm = ChatOpenAI(
+        model=model_name,
+        base_url=base_url,
+        stream_usage=True,
+        temperature=temperature,
+        max_tokens=2048,
+        timeout=600,
+        callbacks=callbacks if callbacks else None,
+    )
+
+    tools = [WikipediaTool(name="search"), LookupTool(name="lookup"), FinishTool(name="finish")]
+    action_prompt = get_action_prompt("hotpotqa")
+    reflection_prompt = get_reflection_prompt("hotpotqa")
+    action_examples = get_action_examples("hotpotqa", fewshot)
+    reflection_examples = get_reflection_examples("hotpotqa", fewshot)
+    evaluator = get_evaluation_function("hotpotqa")
+
+    agent = ReflexionAgent(
+        actor_llm=llm,
+        actor_prompt=action_prompt,
+        actor_examples=action_examples,
+        reflect_llm=llm,
+        reflect_prompt=reflection_prompt,
+        reflect_examples=reflection_examples,
+        tools=tools,
+        context_limit=context_limit,
+        workload="hotpotqa",
+        max_steps=iteration_limit,
+        evaluator=evaluator,
+        print_log=print_log,
+    )
+
+    question = sample["question"]
+    label = sample.get("answer", "")
+    agent.set_qa(question)
+
+    output = ""
+    total_iterations = 0
+    for trial in range(reflection_limit):
+        try:
+            ispass, _ = agent.evaluator(output, label)
+            if ispass:
+                break
+            # Each non-first trial triggers a reflection inside agent.run()
+            # (agent.run() calls self.reflect() before re-running).
+            if trial > 0:
+                try:
+                    from measurement.chat_wrapper import TRACE
+                    trace_obj = TRACE.get()
+                    trace_obj.n_reflections += 1
+                except (LookupError, ImportError):
+                    pass
+            output = agent.run()
+            total_iterations += getattr(agent, "step_n", 0)
+        except KeyboardInterrupt:
+            raise
+        except Exception as e:
+            output = f"Error: {e}"
+
+    return {
+        "answer": output,
+        "raw_messages": list(getattr(agent, "scratchpad_list", [])),
+        "iterations": total_iterations,
+    }
+
