+def run_single_query(sample: dict, agent_kwargs: dict) -> dict:
+    """Run LLMCompiler on one HotpotQA sample.
+
+    Args:
+        sample: HotpotQA dataset entry with 'question' and 'answer'.
+        agent_kwargs:
+            fewshot (int): in-context examples.
+            iteration_limit (int): unused (kept for uniformity).
+            max_replan (int): max plan/execute/join cycles.
+            max_chat_history (int): replan context window size.
+            callbacks (list[BaseCallbackHandler] | None).
+            model (str), host (str | None), port (int | None),
+            temperature (float), print_log (bool).
+
+    Returns:
+        dict with keys: answer, raw_messages, iterations.
+    """
+    from src.agents.LLMCompiler.configs.hotpotqa.tools import tools as hotpot_tools, clear_pages
+    from src.agents.LLMCompiler.configs.hotpotqa.prompt import (
+        get_output_prompt,
+        get_planner_prompt,
+    )
+
+    callbacks = agent_kwargs.get("callbacks") or []
+    fewshot = int(agent_kwargs.get("fewshot", 1))
+    max_replan = int(agent_kwargs.get("max_replan", 10))
+    max_chat_history = int(agent_kwargs.get("max_chat_history", 10))
+    model_name = agent_kwargs.get("model", "Meta-Llama-3.1-8B-Instruct-Q4_K_M")
+    host = agent_kwargs.get("host")
+    port = agent_kwargs.get("port")
+    temperature = float(agent_kwargs.get("temperature", 0.0))
+    print_log = bool(agent_kwargs.get("print_log", False))
+
+    output_prompt = get_output_prompt(fewshot)
+    planner_prompt = get_planner_prompt(fewshot)
+
+    def _make_llm():
+        m = get_model(
+            model_name=model_name,
+            host=host,
+            port=port,
+            temperature=temperature,
+            max_tokens=2048,
+        )
+        bound = m.bind(timeout=600)
+        if callbacks:
+            bound = bound.with_config({"callbacks": callbacks})
+        return bound
+
+    llm = _make_llm()
+    planner_llm = _make_llm()
+
+    agent = LLMCompiler(
+        tools=hotpot_tools,
+        planner_llm=planner_llm,
+        planner_example_prompt=planner_prompt,
+        planner_example_prompt_replan=planner_prompt + "\nConsidering the previous plans and observations, please plan for the next steps.",
+        planner_stop=[END_OF_PLAN],
+        planner_stream=True,
+        agent_llm=llm,
+        joinner_prompt=output_prompt,
+        joinner_prompt_final=output_prompt + f"\nThis is the last trial, please think carefully and answer with {JOINNER_FINISH}(answer).",
+        max_replans=max_replan,
+        end_condition=None,
+        max_chat_history=max_chat_history,
+        print_log=print_log,
+    )
+
+    question = sample["question"]
+
+    try:
+        loop = asyncio.get_event_loop()
+        if loop.is_running():
+            raise RuntimeError("event loop already running")
+    except RuntimeError:
+        loop = asyncio.new_event_loop()
+        asyncio.set_event_loop(loop)
+
+    try:
+        raw_answer = loop.run_until_complete(agent.arun(question, callbacks=callbacks if callbacks else None))
+    except Exception as e:
+        raw_answer = f"Error: {e}"
+
+    try:
+        clear_pages()
+    except Exception:
+        pass
+
+    output = parse_answer(raw_answer) if raw_answer else ""
+    iterations = int(getattr(agent, "current_iter", 0) or 0) + 1
+
+    return {
+        "answer": output,
+        "raw_messages": [],
+        "iterations": iterations,
+    }
+
+
