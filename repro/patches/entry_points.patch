+            temperature (float): sampling temperature.
+            print_log (bool): verbose log.
+
+    Returns:
+        dict with keys: answer, raw_messages, iterations.
+    """
+    from src.tools.hotpotqa_tools.wikipedia import WikipediaTool, LookupTool, FinishTool
+    from src.agents.ReAct.prompt.hotpotqa import get_system_prompt
+
+    callbacks = agent_kwargs.get("callbacks") or []
+    fewshot = int(agent_kwargs.get("fewshot", 0))
+    iteration_limit = int(agent_kwargs.get("iteration_limit", 30))
+    model_name = agent_kwargs.get("model", "Meta-Llama-3.1-8B-Instruct-Q4_K_M")
+    base_url = agent_kwargs.get("base_url")
+    temperature = float(agent_kwargs.get("temperature", 0.0))
+    print_log = bool(agent_kwargs.get("print_log", False))
+
+    model = ChatOpenAI(
+        model=model_name,
+        base_url=base_url,
+        stream_usage=True,
+        stop="\nObservation:",
+        temperature=temperature,
+        max_tokens=2048,
+        timeout=600,
+        callbacks=callbacks if callbacks else None,
+    )
+
+    system_prompt = get_system_prompt(fewshots=min(fewshot, 5))
+    tools = [WikipediaTool(name="search"), LookupTool(name="lookup"), FinishTool(name="finish")]
+    langgraph_agent_executor = create_react_agent(model, tools=tools, print_log=print_log)
+
+    question = sample["question"]
+    messages = [("system", system_prompt), ("human", question)]
+
+    final_chunk = None
+    iterations = 0
+    raw_messages = []
+    try:
+        for num, chunk in enumerate(
+            langgraph_agent_executor.stream(
+                {"messages": messages},
+                stream_mode="values",
+                config={
+                    "recursion_limit": iteration_limit,
+                    "callbacks": callbacks if callbacks else None,
+                },
+            )
+        ):
+            final_chunk = chunk
+            iterations = num + 1
+    except GraphRecursionError:
+        pass
+
+    if final_chunk is not None and final_chunk.get("messages"):
+        raw_messages = final_chunk["messages"]
+        answer = parse_answer(final_chunk["messages"][-1].content)
+    else:
+        answer = ""
+
+    return {
+        "answer": answer,
+        "raw_messages": raw_messages,
+        "iterations": iterations,
+    }
+
