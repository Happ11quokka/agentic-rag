+def run_single_query(sample: dict, agent_kwargs: dict) -> dict:
+    """Run LATS on one HotpotQA sample.
+
+    Args:
+        sample: HotpotQA dataset entry with 'question' and 'answer'.
+        agent_kwargs:
+            fewshot (int): in-context examples.
+            iteration_limit (int): MCTS iterations.
+            max_depth (int): tree max depth.
+            n_generate_sample (int): branching factor (children per expand).
+            sampling_temperature (float): node sampling temperature.
+            callbacks (list[BaseCallbackHandler] | None).
+            model (str), base_url (str | None), temperature (float),
+            print_log (bool).
+
+    Returns:
+        dict with keys: answer, raw_messages, iterations.
+    """
+    callbacks = agent_kwargs.get("callbacks") or []
+    fewshot = int(agent_kwargs.get("fewshot", 0))
+    iteration_limit = int(agent_kwargs.get("iteration_limit", 30))
+    max_depth = int(agent_kwargs.get("max_depth", 7))
+    n_generate_sample = int(agent_kwargs.get("n_generate_sample", 5))
+    sampling_temperature = float(agent_kwargs.get("sampling_temperature", 1.0))
+    model_name = agent_kwargs.get("model", "Meta-Llama-3.1-8B-Instruct-Q4_K_M")
+    base_url = agent_kwargs.get("base_url")
+    temperature = float(agent_kwargs.get("temperature", 0.0))
+    print_log = bool(agent_kwargs.get("print_log", False))
+
+    client = OpenAIChatClient(
+        model=model_name,
+        base_url=base_url,
+        temperature=temperature,
+    )
+    # Inject max_tokens=2048, timeout=600, and callbacks into the underlying ChatOpenAI.
+    bind_kwargs: Dict[str, Any] = {"max_tokens": 2048, "timeout": 600}
+    bound = client.llm.bind(**bind_kwargs)
+    if callbacks:
+        bound = bound.with_config({"callbacks": callbacks})
+    client.llm = bound
+
+    env = HotpotWikiEnv()
+    task = HotpotQATask(client=client, fewshot=fewshot)
+    config = HotpotLATSConfig(
+        iterations=iteration_limit,
+        n_generate_sample=n_generate_sample,
+        max_depth=max_depth,
+        sampling_temperature=sampling_temperature,
+        print_log=print_log,
+    )
+    runner = HotpotLATSRunner(env=env, task=task, client=client, config=config)
+
+    question = sample["question"]
+    label = sample.get("answer", "")
+    result = runner.run(question=question, answer=label)
+
+    best_node = result.get("best_node")
+    try:
+        from measurement.chat_wrapper import TRACE
+        trace_obj = TRACE.get()
+        # Use depth as a proxy for expansions on the winning path; fall back to iteration_limit.
+        trace_obj.n_tree_expansions = int(getattr(best_node, "depth", iteration_limit) or iteration_limit)
+    except (LookupError, ImportError):
+        pass
+
+    return {
+        "answer": result.get("output", ""),
+        "raw_messages": [],
+        "iterations": int(getattr(best_node, "depth", 0) or 0),
+    }
+
+
